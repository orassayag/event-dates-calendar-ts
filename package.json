{
  "name": "event-dates-calendar-ts",
  "version": "1.0.0",
  "private": false,
  "description": "A Node.js TypeScript application to create and manage personalized calendar TXT files by combining events from multiple sources including Israeli holidays, US holidays, birthdays, anniversaries, and routine tasks with automated validation and synchronization.",
  "repository": {
    "type": "git",
    "url": "git://github.com/orassayag/event-dates-calendar-ts.git"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "calendar",
    "events",
    "scheduler",
    "tasks",
    "holidays",
    "israeli-calendar",
    "us-holidays",
    "automation",
    "jsdom",
    "web-scraping"
  ],
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "start": "tsx src/runner.ts",
    "script": "tsx src/runner.ts",
    "create": "tsx src/runner.ts create",
    "sync": "tsx src/runner.ts sync",
    "validate": "tsx src/runner.ts validate",
    "stop-counter": "tsx src/runner.ts stop-counter",
    "search": "tsx src/runner.ts search",
    "build": "tsc"
  },
  "author": "Or Assayag <orassayag@gmail.com>",
  "contributors": [
    {
      "name": "Or Assayag",
      "email": "orassayag@gmail.com",
      "url": "https://github.com/orassayag"
    }
  ],
  "files": [
    ".vscode",
    "dist",
    "misc",
    "node_modules",
    "sources",
    "sources/examples",
    "src",
    ".gitignore",
    ".prettierrc",
    "eslint.config.mjs",
    "CONTRIBUTING.md",
    "LICENSE",
    "INSTRUCTIONS.md",
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "README.md",
    "tsconfig.json"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "jsdom": "^29.1.1"
  }
}
